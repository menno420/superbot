# The repo root ignores dist/, but the generated single-file bootstrap IS the
# distributable artifact and must be committed (plan §1: "dist/bootstrap.py —
# THE single self-expanding file (committed)"). Re-include just that one file.
!dist/
dist/*
!dist/bootstrap.py

# pip/setuptools build artifacts (a local `pip install ./substrate-kit` run
# must never dirty the tree).
build/
src/*.egg-info/
__pycache__/
