      "Bash(git branch*)",
      "Bash(git rev-list*)",
      "Bash(git rev-parse*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(python3.10 scripts/check_*)",
      "Bash(python3.10 scripts/context_map.py*)",
      "Bash(python3.10 scripts/hermes/*)",
      "Bash(python3.10 -m pytest*)",
      "Bash(python3.10 -m black*)",
      "Bash(python3.10 -m isort*)",
      "Bash(python3.10 -m ruff*)",
      "Bash(python3.10 -m mypy*)",
      "Bash(python3.10 substrate-kit/src/build_bootstrap.py*)",
      "Bash(python3.10 substrate-kit/dist/bootstrap.py*)",
      "Bash(mktemp*)",
      "Bash(ls*)",
      "Bash(wc*)",
      "Bash(echo*)",
      "Bash(date*)",
      "Bash(chmod +x*)",
      "mcp__github__pull_request_read",
      "mcp__github__list_pull_requests",
      "mcp__github__create_pull_request",
      "mcp__github__update_pull_request",
      "mcp__github__merge_pull_request",
      "mcp__github__subscribe_pr_activity",
      "mcp__github__unsubscribe_pr_activity",
      "mcp__github__get_file_contents",
      "mcp__github__list_commits",
      "mcp__github__get_commit",
      "mcp__github__get_job_logs",
      "mcp__github__actions_list",

      "mcp__Claude_Code_Remote",
      "mcp__github",
      "mcp__codegraph",
      "mcp__context7",

      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(find*)",
      "Bash(pwd*)",
      "Bash(sed*)",
      "Bash(awk*)",
      "Bash(jq*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(cut*)",
      "Bash(tr *)",
      "Bash(diff*)",
      "Bash(which*)",
      "Bash(test *)",
      "Bash(true)",
      "Bash(tree*)",
      "Bash(comm*)",
      "Bash(column*)",
      "Bash(stat*)",
      "Bash(basename*)",
      "Bash(dirname*)",
      "Bash(realpath*)",
      "Bash(printf*)",
      "Bash(mkdir*)",
      "Bash(touch*)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln -s*)",
      "Bash(git pull*)",
      "Bash(git reset*)",
      "Bash(git cherry-pick*)",
      "Bash(git rebase*)",
      "Bash(git remote*)",
      "Bash(git config*)",
      "Bash(git worktree*)",
      "Bash(git ls-files*)",
      "Bash(git ls-tree*)",
      "Bash(git blame*)",
      "Bash(git describe*)",
      "Bash(git tag*)",
      "Bash(git cat-file*)",
      "Bash(git apply*)",
      "Bash(git shortlog*)",
      "Bash(git clean --dry-run*)",
      "Bash(git clean -n*)",
      "Bash(python3.10 -c*)",
      "Bash(python3.10 scripts/*)",
      "Bash(python3.10 tools/*)",
      "Bash(python3.10 *)",
      "Bash(python3.10 -m venv*)",
      "Bash(python3.10 -m json.tool*)",
      "Bash(rm -f*)",
      "Bash(rm /tmp/*)",
      "Bash(rm _*)",
      "Bash(python3 /tmp/*)",
      "Bash(npx -y @optave/codegraph*)",
      "Bash(npx @optave/codegraph*)",
      "Bash(curl*)",
      "Bash(timeout*)"
    ],
    "ask": [
      "Bash(rm -r*)",
      "Bash(rm -R*)",
      "Bash(rm -fr*)",
      "Bash(rm -fR*)",
      "Bash(rmdir*)",
      "Bash(git push --force )",
      "Bash(git push --force *)",
      "Bash(git push -f*)",
      "Bash(git clean -f*)",
      "Bash(railway*)",
      "Bash(sudo*)",
      "Bash(psql*)",
      "Bash(pg_dump*)",
      "Bash(pg_restore*)",
      "Bash(wget*)",
      "Bash(docker*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" && python3.10 scripts/claude_pre_edit.py",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" && python3.10 scripts/check_branch_freshness.py --event pretooluse",
            "timeout": 20
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" && python3.10 scripts/claude_post_edit.py",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" && python3.10 scripts/claude_pr_subscribe_reminder.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" && python3.10 scripts/claude_stop_check.py",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" && python3.10 scripts/check_branch_freshness.py --event stop",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" && bash scripts/claude_session_start.sh",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
